---
import BaseLayout from "../layouts/BaseLayout.astro";
import Divider from "../components/Divider.astro";
---

<BaseLayout title="Equipment" lang="en">
  <article class="page equip-page">
    <header class="page-head">
      <h1>Equipment</h1>
    </header>

    <figure class="hero">
      <img
        src="/img/header_eqip4.jpg"
        alt=""
        width="1218"
        height="180"
        loading="eager"
        decoding="async"
      />
    </figure>

    <section class="equip-page__instruments" aria-label="Instruments">
      <section class="equip-card" aria-label="Strumento realizzato da Marco Nolli">
        <h2 class="equip-card__title">Strumento realizzato da Marco Nolli</h2>
        <p class="equip-card__subtitle">Copia del contrabbasso Gaetano Rossi del 1847</p>

        <figure class="equip-card__frame frame">
          <img
            src="/img/claudio_marzolo_strumento_marco_nolli.jpg"
            alt=""
            width="551"
            height="1000"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </section>

      <section class="equip-card" aria-label="Strumento di liuteria veneta">
        <h2 class="equip-card__title">Strumento di liuteria veneta</h2>
        <p class="equip-card__subtitle">Realizzato all'inizio del 1900</p>

        <figure class="equip-card__frame frame">
          <img
            src="/img/contrabbasso_large.jpg"
            alt=""
            width="600"
            height="1194"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </section>
    </section>

    <Divider ornament />

    <section class="equip-page__bow" aria-label="Archetto">
      <p class="equip-card__subtitle equip-page__bow-caption">Archetto in pernambuco di manifattura tedesca.</p>

      <figure class="equip-page__bow-frame frame">
        <img
          src="/img/archetto.jpg"
          alt="Archetto in pernambuco di manifattura tedesca"
          width="1440"
          height="964"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>
  </article>
</BaseLayout>
